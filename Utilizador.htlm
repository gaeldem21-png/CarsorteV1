<!doctype html>
<html lang="pt">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Área do Utilizador · CarSorte</title>
  <style>
    :root{
      --bg:#060606;
      --panel:#101010;
      --gold:#f4c542;
      --line:rgba(255,255,255,.08);
      --muted:#a9a9a9;
      --shadow:0 18px 40px rgba(0,0,0,.35);
    }
    *{box-sizing:border-box}
    body{
      margin:0;
      font-family:Arial, Helvetica, sans-serif;
      background:
        radial-gradient(circle at top, rgba(244,197,66,.10), transparent 26%),
        var(--bg);
      color:#fff;
    }
    a{text-decoration:none;color:inherit}
    .container{max-width:1200px;margin:0 auto;padding:0 20px}
    .topbar{
      position:sticky;top:0;z-index:20;
      background:rgba(6,6,6,.9);
      border-bottom:1px solid var(--line);
      backdrop-filter:blur(10px);
    }
    .nav{display:flex;justify-content:space-between;align-items:center;padding:18px 0}
    .brand{display:flex;align-items:center;gap:12px}
    .logo{
      width:46px;height:46px;border-radius:16px;background:var(--gold);
      color:#000;display:grid;place-items:center;font-size:24px;font-weight:900;
    }
    .brand h1{margin:0;color:var(--gold);font-size:28px}
    .brand small{display:block;color:#888}
    .navlinks{display:flex;gap:22px;align-items:center}
    .navlinks a{color:#ddd;font-size:14px}
    .navlinks a:hover{color:var(--gold)}
    .logout{
      background:var(--gold);color:#000;padding:10px 14px;border-radius:14px;font-weight:800;
    }

    .hero{padding:34px 0}
    .hero-box{
      background:#101010;border:1px solid var(--line);border-radius:28px;padding:28px;box-shadow:var(--shadow);
      display:grid;grid-template-columns:1.2fr .8fr;gap:20px;align-items:center;
    }
    .hero-box h2{margin:0;font-size:40px}
    .muted{color:var(--muted)}
    .premium-badge{
      display:inline-block;
      margin-top:12px;
      padding:10px 14px;
      border-radius:999px;
      background:rgba(244,197,66,.1);
      border:1px solid rgba(244,197,66,.2);
      color:#ffe08a;
      font-weight:800;
      font-size:14px;
    }

    .stats{
      display:grid;
      grid-template-columns:repeat(4,1fr);
      gap:16px;
      margin-top:26px;
    }
    .stat{
      background:#101010;border:1px solid var(--line);border-radius:22px;padding:20px;text-align:center;box-shadow:var(--shadow);
    }
    .stat strong{display:block;font-size:32px;color:var(--gold)}
    .stat span{font-size:14px;color:#8f8f8f}

    .grid{
      display:grid;
      grid-template-columns:2fr 1fr;
      gap:22px;
      padding-bottom:60px;
    }
    .panel{
      background:#101010;border:1px solid var(--line);border-radius:26px;padding:24px;box-shadow:var(--shadow);
    }
    .panel h3{margin-top:0;font-size:28px}
    .ticket-list,.history-list,.side-list{display:grid;gap:14px}
    .ticket,.history-item,.side-item{
      background:#0b0b0b;border:1px solid var(--line);border-radius:18px;padding:16px;
    }
    .row{display:flex;justify-content:space-between;gap:10px;align-items:center}
    .status{
      display:inline-block;
      padding:7px 10px;
      border-radius:999px;
      font-size:12px;
      font-weight:800;
      background:rgba(244,197,66,.1);
      color:#ffe08a;
      border:1px solid rgba(244,197,66,.2);
    }
    .small{font-size:13px;color:#999}
    .side-title{font-size:18px;font-weight:900;margin-bottom:12px}
    .cta{
      display:inline-block;
      background:var(--gold);color:#000;padding:12px 16px;border-radius:14px;font-weight:900;
    }

    @media (max-width:980px){
      .hero-box,.grid,.stats{grid-template-columns:1fr}
      .navlinks{display:none}
      .hero-box h2{font-size:32px}
    }
  </style>
</head>
<body>

  <div class="topbar">
    <div class="container nav">
      <div class="brand">
        <div class="logo">👤</div>
        <div>
          <h1>Área do Utilizador</h1>
          <small>CarSorte by DEM Automóveis</small>
        </div>
      </div>
      <div class="navlinks">
        <a href="index.html">Site público</a>
        <a href="#bilhetes">Os meus bilhetes</a>
        <a href="#historico">Histórico</a>
        <a href="#conta">Conta</a>
        <a href="admin.html">Admin</a>
        <a class="logout" href="index.html">Sair</a>
      </div>
    </div>
  </div>

  <section class="container hero">
    <div class="hero-box">
      <div>
        <h2>Olá, João 👋</h2>
        <p class="muted">Bem-vindo à sua área pessoal. Aqui pode acompanhar os seus bilhetes, participações, histórico e estado Premium.</p>
        <div class="premium-badge">Premium Club ativo</div>
      </div>
      <div>
        <p class="small">Próximo sorteio</p>
        <h3 style="margin:0 0 8px 0;color:#f4c542">BMW Série 1 Pack M</h3>
        <p class="muted" style="margin:0">Sorteio em 04 dias · 12h · 18m</p>
      </div>
    </div>

    <div class="stats">
      <div class="stat"><strong>42</strong><span>Bilhetes totais</span></div>
      <div class="stat"><strong>3</strong><span>Sorteios ativos</span></div>
      <div class="stat"><strong>1</strong><span>Conta Premium</span></div>
      <div class="stat"><strong>0</strong><span>Prémios ganhos</span></div>
    </div>
  </section>

  <section class="container grid">
    <div>
      <div class="panel" id="bilhetes">
        <h3>Os meus bilhetes</h3>
        <div class="ticket-list">
          <div class="ticket">
            <div class="row">
              <strong>BMW Série 1 Pack M</strong>
              <span class="status">Ativo</span>
            </div>
            <p class="small">Bilhetes: #A1032 · #A1033 · #A1034 · #A1035 · #A1036</p>
          </div>

          <div class="ticket">
            <div class="row">
              <strong>Mercedes Classe A</strong>
              <span class="status">Ativo</span>
            </div>
            <p class="small">Bilhetes: #M2241 · #M2242 · #M2243 · #M2244 · #M2245 · #M2246 · #M2247 · #M2248 · #M2249 · #M2250</p>
          </div>

          <div class="ticket">
            <div class="row">
              <strong>Citroën Jumpy Business</strong>
              <span class="status">Ativo</span>
            </div>
            <p class="small">Bilhete: #J7105</p>
          </div>
        </div>
      </div>

      <div class="panel" id="historico" style="margin-top:22px">
        <h3>Histórico de participações</h3>
        <div class="history-list">
          <div class="history-item">
            <div class="row">
              <strong>Pack 5 bilhetes · BMW Série 1</strong>
              <span class="small">10€</span>
            </div>
            <p class="small">Data: 05/03/2026</p>
          </div>

          <div class="history-item">
            <div class="row">
              <strong>Pack 10 bilhetes · Mercedes Classe A</strong>
              <span class="small">20€</span>
            </div>
            <p class="small">Data: 07/03/2026</p>
          </div>

          <div class="history-item">
            <div class="row">
              <strong>1 bilhete · Citroën Jumpy</strong>
              <span class="small">2,50€</span>
            </div>
            <p class="small">Data: 08/03/2026</p>
          </div>
        </div>
      </div>
    </div>

    <div>
      <div class="panel" id="conta">
        <div class="side-title">Resumo da conta</div>
        <div class="side-list">
          <div class="side-item">
            <strong>Nome</strong>
            <p class="small">João Ferreira</p>
          </div>
          <div class="side-item">
            <strong>Email</strong>
            <p class="small">joao@email.pt</p>
          </div>
          <div class="side-item">
            <strong>Estado Premium</strong>
            <p class="small">Ativo · 3€/mês</p>
          </div>
          <div class="side-item">
            <strong>Total investido</strong>
            <p class="small">32,50€</p>
          </div>
        </div>
      </div>

      <div class="panel" style="margin-top:22px">
        <div class="side-title">Ações rápidas</div>
        <div class="side-list">
          <div class="side-item">
            <a class="cta" href="index.html#sorteios">Participar em sorteios</a>
          </div>
          <div class="side-item">
            <a class="cta" href="index.html#premium">Gerir Premium Club</a>
          </div>
          <div class="side-item">
            <a class="cta" href="index.html#contacto">Contactar suporte</a>
          </div>
        </div>
      </div>
    </div>
  </section>

</body>
</html>
